# ===========================================================================
# CloudApp Platform — Environment Variables
# ===========================================================================
# USAGE:
#   ./scripts/showcase-preflight.sh --mode hero
#   cp .env.example .env    # then edit .env with real values
#   docker compose -f docker-compose-infrastructure.yml up -d
#   docker compose -f docker-compose-app.yml up -d
#
# NEVER commit .env to version control.
# ===========================================================================

# --- JWT Authentication ---------------------------------------------------
# REQUIRED — generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48
# Token lifetime in ms (default 4h; was 10 days — reduced for security)
JWT_EXPIRATION_MS=14400000
# Absolute file paths on the host for JWT RSA keys (not committed).
# Quick setup: ./scripts/setup-env-jwt-keys.sh
JWT_PRIVATE_KEY_FILE=/absolute/path/to/secrets/jwt-private-key.pem
JWT_PUBLIC_KEY_FILE=/absolute/path/to/secrets/jwt-public-key.pub

# --- Internal Service-to-Service Auth ------------------------------------
# Generate separate credentials so one internal caller cannot impersonate every
# other caller.
INTERNAL_GATEWAY_ADMIN_TOKEN=
INTERNAL_AI_ORCHESTRATION_TOKEN=

# --- Optional local demo-user seeding -------------------------------------
# Disabled by default. Set these only if you want local startup to create
# known CloudApp users for manual testing or the official showcase tour.
CLOUDAPP_SEED_DEMO_USERS_ENABLED=false
CLOUDAPP_SEED_DEMO_USERS_ADMIN_USERNAME=showcaseadmin
CLOUDAPP_SEED_DEMO_USERS_ADMIN_PASSWORD=ShowcaseAdmin123
CLOUDAPP_SEED_DEMO_USERS_REGULAR_USERNAME=showcaseuser
CLOUDAPP_SEED_DEMO_USERS_REGULAR_PASSWORD=ShowcaseUser123

# --- PostgreSQL — CloudApp ------------------------------------------------
POSTGRES_USER=websitemaster
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cloudappdb

# --- PostgreSQL — ML Pipeline ---------------------------------------------
POSTGRES_ML_USER=segmentmaster
POSTGRES_ML_PASSWORD=CHANGE_ME
POSTGRES_ML_DB=segmentationdb

# --- MySQL — Petstore -----------------------------------------------------
MYSQL_ROOT_USERNAME=root
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=petstore

# --- MongoDB — Chat -------------------------------------------------------
MONGO_USER=websitemaster
MONGO_PASSWORD=CHANGE_ME
MONGO_DB=cloudappdb

# --- MongoDB — AI A/B Testing --------------------------------------------
MONGO_ABTEST_USER=admin
MONGO_ABTEST_PASSWORD=CHANGE_ME
MONGO_ABTEST_ORCH_USER=orchestration_user
MONGO_ABTEST_ORCH_PASSWORD=CHANGE_ME

# --- Jira Integration (extract token from compose!) -----------------------
JIRA_DOMAIN=https://your-instance.atlassian.net
JIRA_API_TOKEN=CHANGE_ME
JIRA_PROJECT_KEY=PROJ
JIRA_EMAIL=you@example.com

# --- Ollama / LLM --------------------------------------------------------
LLM_MODEL=qwen3:1.7b
LLM_MODEL_EMBEDDING=qwen3-embedding:4b
NEXT_PUBLIC_REMOTE_JIRA_URL=http://localhost:5003
NEXT_PUBLIC_REMOTE_CHATLLM_URL=http://localhost:5333
# Shell/browser origins allowed to call the Jira + ChatLLM remote /api/* routes.
AI_REMOTE_CORS_ALLOWED_ORIGINS=http://localhost:5001,http://localhost:80,http://localhost:8080,https://localhost,https://localhost:443

# --- OpenTelemetry --------------------------------------------------------
OTEL_ENABLED=true

# --- Grafana (metrics dashboard) ------------------------------------------
GRAFANA_PASSWORD=CHANGE_ME

# --- Umami analytics -------------------------------------------------------
UMAMI_DB_NAME=umamiportfolio
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=CHANGE_ME
UMAMI_APP_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
NEXT_PUBLIC_UMAMI_HOST_URL=http://localhost:3001
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_DOMAINS=localhost,127.0.0.1

# --- Module federation
CLOUDAPP_URL=http://next-nginx-jwt:80/cloudapp
PETSTORE_URL=http://next-nginx-jwt:80/petstore
VEHICLES_URL=http://next-nginx-jwt:80/vehicles
ML_URL=http://next-nginx-jwt:80/mlops-segmentation

# --- AI Orchestration layer
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=user_documents
CHROMA_PERSIST_DIR=/data/chroma

ENABLE_CHECKPOINTING=true
ENABLE_HITL=true
ENABLE_PARALLEL=true
ENABLE_ERROR_HANDLING=true
ENABLE_AB_TESTING=true

REDIS_MAX_CONNECTIONS=50
ENVIRONMENT=development

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
RAG_SEARCH_K=3

HTTP_TIMEOUT=10
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE=20

LOG_LEVEL=INFO
LOG_FORMAT=json
