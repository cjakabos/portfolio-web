{
  "name": "cloudapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next; NEXT_PRIVATE_LOCAL_WEBPACK=true next dev -p 5001",
    "build": "NEXT_PRIVATE_LOCAL_WEBPACK=true next build",
    "start": "NEXT_PRIVATE_LOCAL_WEBPACK=true next start -p 5001",
    "test": "NODE_PATH=./node_modules jest",
    "test:mobile:smoke": "NODE_PATH=./node_modules jest --config jest.config.cjs --runInBand --testPathPatterns=src/mobile/capacitorConfig.smoke.test.ts",
    "test:ios:smoke": "NODE_PATH=./node_modules jest --config jest.config.cjs --runInBand --testPathPatterns=src/mobile/iosPackaging.smoke.test.ts",
    "format": "prettier --write .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "next lint",
    "check:bundle-budget": "node ./scripts/check-bundle-budget.mjs",
    "build:budget": "npm run build && npm run check:bundle-budget",
    "playwright:test": "NODE_PATH=./node_modules npx playwright test -c ../../playwright.config.ts",
    "playwright:open": "NODE_PATH=./node_modules npx playwright test --ui --project=chromium -c ../../playwright.config.ts",
    "playwright:open:all": "NODE_PATH=./node_modules npx playwright test --ui --project=chromium --project=firefox --project=webkit --workers=1 --retries=2 -c ../../playwright.config.ts",
    "playwright:headed": "NODE_PATH=./node_modules npx playwright test --headed -c ../../playwright.config.ts",
    "playwright:debug": "NODE_PATH=./node_modules npx playwright test --debug -c ../../playwright.config.ts",
    "playwright:install": "npx playwright install chromium firefox webkit",
    "mobile:doctor": "npx cap doctor",
    "mobile:add:android": "npx cap add android",
    "mobile:add:ios": "npx cap add ios",
    "mobile:copy": "npm run build && npx cap copy",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:android": "npm run mobile:sync && npx cap open android",
    "mobile:ios": "npm run mobile:sync && npx cap open ios"
  },
  "dependencies": {
    "@portfolio/api-clients": "0.1.0",
    "@portfolio/auth": "0.1.0",
    "@portfolio/ui": "0.1.0",
    "@ai-sdk/react": "3.0.67",
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.5.0",
    "@capacitor/keyboard": "^7.0.5",
    "@capacitor/status-bar": "^7.0.5",
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@mui/x-data-grid": "^8.11.2",
    "@mui/x-tree-view": "^8.11.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@tanstack/react-table": "^8.21.3",
    "@types/leaflet": "^1.9.20",
    "ai": "^6.0.27",
    "lucide-react": "^0.454.0",
    "next": "15.3.8",
    "next-themes": "^0.4.6",
    "ollama-ai-provider-v2": "^1.3.1",
    "react": "19.1.2",
    "react-datepicker": "^8.7.0",
    "react-dom": "19.1.2",
    "react-leaflet": "^5.0.0-rc.2",
    "sockjs-client": "^1.6.1",
    "tailwindcss-safe-area": "^1.3.0",
    "webpack": "5.99.9",
    "webstomp-client": "^1.2.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@module-federation/enhanced": "0.0.0-next-20250618045528",
    "@module-federation/nextjs-mf": "0.0.0-next-20250618045528",
    "@module-federation/runtime": "0.0.0-next-20250618045528",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "24.3.1",
    "@types/react": "^19.1.8",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.29.0",
    "eslint-config-next": "15.3.8",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "typescript": "5.9.2"
  }
}
