# ===========================================================================
# Dockerfile_FE — Next.js Frontend Services (Shell + Remotes)
#
# FIX (4.9): Replaced `npm install -f` with `npm ci` for deterministic,
#   reproducible builds. Requires package-lock.json to be present.
# FIX (4.6): Added HEALTHCHECK for the Next.js server.
# FIX (4.5): NEXT_PUBLIC_REMOTE_* env vars are now passed at build time
#   so Module Federation remotes are configurable per environment.
# ===========================================================================

# Prefer Debian/glibc here. Tailwind v4 and Next.js CSS tooling depend on
# native optional packages that have been unreliable on Alpine/musl in CI.
FROM node:20-slim AS base

# Install dependencies only when needed
FROM base AS deps
ARG SERVICE_PATH
WORKDIR /workspace

# Copy the monorepo workspace manifests first so local @portfolio/* packages
# resolve from the root lockfile instead of the public npm registry.
COPY ./package.json ./package-lock.json ./
COPY ./packages/contracts/package.json ./packages/contracts/package.json
COPY ./packages/api-clients/package.json ./packages/api-clients/package.json
COPY ./packages/auth/package.json ./packages/auth/package.json
COPY ./packages/ui/package.json ./packages/ui/package.json
COPY ./frontend/cloudapp-shell/package.json ./frontend/cloudapp-shell/package.json
COPY ./frontend/remote/openmaps/package.json ./frontend/remote/openmaps/package.json
COPY ./frontend/remote/jira/package.json ./frontend/remote/jira/package.json
COPY ./frontend/remote/chatllm/package.json ./frontend/remote/chatllm/package.json
COPY ./frontend/remote/mlops/package.json ./frontend/remote/mlops/package.json
COPY ./frontend/remote/petstore/package.json ./frontend/remote/petstore/package.json
COPY ./frontend/remote/moduletemplate/package.json ./frontend/remote/moduletemplate/package.json
COPY ./ai-orchestration/ai-orchestration-monitor/package.json ./ai-orchestration/ai-orchestration-monitor/package.json

# npm ci is the production-grade approach: it installs from the lockfile
# exactly, fails if lockfile is out of sync, and is faster than npm install.
# Some npm versions intermittently skip optional native bindings in containers.
# Install the matching Tailwind and lightningcss Linux package explicitly when
# npm leaves it out so Next.js CSS builds stay deterministic in CI.
# Retry npm commands because CI registry fetches can occasionally fail even
# when the lockfile and package selection are otherwise correct.
RUN npm_retry() { \
      ATTEMPT=1; \
      until "$@"; do \
        if [ "$ATTEMPT" -ge 3 ]; then \
          return 1; \
        fi; \
        echo "Retrying npm command ($((ATTEMPT + 1))/3): $*"; \
        ATTEMPT=$((ATTEMPT + 1)); \
        sleep 10; \
      done; \
    } \
 && npm_retry npm ci --workspace "$SERVICE_PATH" --include-workspace-root=false --include=optional \
 && if ldd --version 2>&1 | grep -qi musl; then NATIVE_LIBC='musl'; else NATIVE_LIBC='gnu'; fi \
 && case "$(node -p "process.arch")" in \
      arm64) NATIVE_ARCH='arm64' ;; \
      x64) NATIVE_ARCH='x64' ;; \
      arm) NATIVE_ARCH='arm-gnueabihf' ;; \
      *) NATIVE_ARCH='' ;; \
    esac \
 && if [ -z "$NATIVE_ARCH" ]; then \
      echo "Unsupported architecture for frontend native fallback: $(node -p "process.arch")" >&2; \
      exit 1; \
    fi \
 && native_package_name() { \
      PREFIX="$1"; \
      if [ "$NATIVE_ARCH" = 'arm-gnueabihf' ]; then \
        printf '%s-arm-gnueabihf' "$PREFIX"; \
      else \
        printf '%s-%s-%s' "$PREFIX" "$NATIVE_ARCH" "$NATIVE_LIBC"; \
      fi; \
    } \
 && queue_native_package() { \
      PACKAGE_NAME="$1"; \
      PACKAGE_VERSION="$2"; \
      if ! (cd "$SERVICE_PATH" && node -e "require('${PACKAGE_NAME}')") >/dev/null 2>&1; then \
        MISSING_NATIVE_PACKAGES="${MISSING_NATIVE_PACKAGES} ${PACKAGE_NAME}@${PACKAGE_VERSION}"; \
      fi; \
    } \
 && verify_native_package() { \
      PACKAGE_NAME="$1"; \
      if ! (cd "$SERVICE_PATH" && node -e "require('${PACKAGE_NAME}')") >/dev/null 2>&1; then \
        echo "Native package still unavailable after install: ${PACKAGE_NAME}" >&2; \
        exit 1; \
      fi; \
    } \
 && MISSING_NATIVE_PACKAGES='' \
 && OXIDE_PACKAGE='' \
 && LIGHTNING_PACKAGE='' \
 && if node -e "const p=require('./${SERVICE_PATH}/package.json');const d={...(p.dependencies||{}),...(p.devDependencies||{})};const t=d.tailwindcss||'';const needsOxide=Boolean(d['@tailwindcss/postcss'])||/^(\\^|~)?4(\\.|$)/.test(t);process.exit(needsOxide?0:1)"; then \
      OXIDE_PACKAGE="$(native_package_name '@tailwindcss/oxide-linux')"; \
      OXIDE_VERSION="$(cd "$SERVICE_PATH" && node -p "require('@tailwindcss/oxide/package.json').version")"; \
      queue_native_package "$OXIDE_PACKAGE" "$OXIDE_VERSION"; \
    fi \
 && if (cd "$SERVICE_PATH" && node -e "require.resolve('lightningcss')") >/dev/null 2>&1; then \
      LIGHTNING_PACKAGE="$(native_package_name 'lightningcss-linux')"; \
      LIGHTNING_VERSION="$(cd "$SERVICE_PATH" && node -p "const path=require('path');const pkg=path.join(path.dirname(require.resolve('lightningcss')),'..','package.json');require(pkg).version")"; \
      queue_native_package "$LIGHTNING_PACKAGE" "$LIGHTNING_VERSION"; \
    fi \
 && if [ -n "$MISSING_NATIVE_PACKAGES" ]; then \
      echo "Installing missing native packages:${MISSING_NATIVE_PACKAGES}"; \
      cd "$SERVICE_PATH" && npm_retry npm install --no-save $MISSING_NATIVE_PACKAGES && cd /workspace; \
    fi \
 && if [ -n "$OXIDE_PACKAGE" ]; then \
      verify_native_package "$OXIDE_PACKAGE"; \
    fi \
 && if [ -n "$LIGHTNING_PACKAGE" ]; then \
      verify_native_package "$LIGHTNING_PACKAGE"; \
    fi


# Rebuild the source code only when needed
FROM base AS builder

ARG NEXT_PRIVATE_LOCAL_WEBPACK
ENV NEXT_PRIVATE_LOCAL_WEBPACK=$NEXT_PRIVATE_LOCAL_WEBPACK
ARG NEXT_PUBLIC_JIRA_PROJECT_KEY
ENV NEXT_PUBLIC_JIRA_PROJECT_KEY=$NEXT_PUBLIC_JIRA_PROJECT_KEY

# Module Federation remote URLs are now configurable via env vars.
# These are baked into the Next.js build, so they must be set at build time.
# Default values point to localhost for local development.
ARG NEXT_PUBLIC_REMOTE_OPENMAPS_URL
ENV NEXT_PUBLIC_REMOTE_OPENMAPS_URL=${NEXT_PUBLIC_REMOTE_OPENMAPS_URL:-http://localhost:5002}
ARG NEXT_PUBLIC_REMOTE_JIRA_URL
ENV NEXT_PUBLIC_REMOTE_JIRA_URL=${NEXT_PUBLIC_REMOTE_JIRA_URL:-http://localhost:5003}
ARG NEXT_PUBLIC_REMOTE_CHATLLM_URL
ENV NEXT_PUBLIC_REMOTE_CHATLLM_URL=${NEXT_PUBLIC_REMOTE_CHATLLM_URL:-http://localhost:5333}
ARG NEXT_PUBLIC_REMOTE_MLOPS_URL
ENV NEXT_PUBLIC_REMOTE_MLOPS_URL=${NEXT_PUBLIC_REMOTE_MLOPS_URL:-http://localhost:5005}
ARG NEXT_PUBLIC_REMOTE_PETSTORE_URL
ENV NEXT_PUBLIC_REMOTE_PETSTORE_URL=${NEXT_PUBLIC_REMOTE_PETSTORE_URL:-http://localhost:5006}
ARG NEXT_PUBLIC_ENABLE_OPENMAPS
ENV NEXT_PUBLIC_ENABLE_OPENMAPS=${NEXT_PUBLIC_ENABLE_OPENMAPS:-true}
ARG NEXT_PUBLIC_ENABLE_CHATLLM
ENV NEXT_PUBLIC_ENABLE_CHATLLM=${NEXT_PUBLIC_ENABLE_CHATLLM:-false}
ARG NEXT_PUBLIC_ENABLE_JIRA
ENV NEXT_PUBLIC_ENABLE_JIRA=${NEXT_PUBLIC_ENABLE_JIRA:-false}
ARG NEXT_PUBLIC_ENABLE_MLOPS
ENV NEXT_PUBLIC_ENABLE_MLOPS=${NEXT_PUBLIC_ENABLE_MLOPS:-false}
ARG NEXT_PUBLIC_ENABLE_PETSTORE
ENV NEXT_PUBLIC_ENABLE_PETSTORE=${NEXT_PUBLIC_ENABLE_PETSTORE:-false}
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL:-http://localhost:80/cloudapp}
ARG NEXT_PUBLIC_GATEWAY_BASE_URL
ENV NEXT_PUBLIC_GATEWAY_BASE_URL=${NEXT_PUBLIC_GATEWAY_BASE_URL:-http://localhost:80}
ARG NEXT_PUBLIC_CHAT_WS_API_URL
ENV NEXT_PUBLIC_CHAT_WS_API_URL=${NEXT_PUBLIC_CHAT_WS_API_URL:-${NEXT_PUBLIC_API_URL:-http://localhost:80/cloudapp}}
ARG NEXT_PUBLIC_UMAMI_HOST_URL
ENV NEXT_PUBLIC_UMAMI_HOST_URL=${NEXT_PUBLIC_UMAMI_HOST_URL:-}
ARG NEXT_PUBLIC_UMAMI_WEBSITE_ID
ENV NEXT_PUBLIC_UMAMI_WEBSITE_ID=${NEXT_PUBLIC_UMAMI_WEBSITE_ID:-}
ARG NEXT_PUBLIC_UMAMI_DOMAINS
ENV NEXT_PUBLIC_UMAMI_DOMAINS=${NEXT_PUBLIC_UMAMI_DOMAINS:-}

ARG SERVICE_PATH
WORKDIR /workspace
COPY --from=deps /workspace ./
COPY ./packages ./packages
COPY ./$SERVICE_PATH ./$SERVICE_PATH

# Next.js collects completely anonymous telemetry data about general usage.
# Learn more here: https://nextjs.org/telemetry
# Uncomment the following line in case you want to disable telemetry during the build.
# ENV NEXT_TELEMETRY_DISABLED 1

WORKDIR /workspace/$SERVICE_PATH
RUN \
  if [ -f package.json ]; then npm run build; \
  else echo "Lockfile not found." && exit 1; \
  fi

# Production image, copy all the files and run next
FROM base AS runner
ARG SERVICE_PATH
ARG SERVICE_PORT
ARG NEXT_PRIVATE_LOCAL_WEBPACK
ARG NEXT_PUBLIC_CHAT_WS_API_URL
ENV NEXT_PRIVATE_LOCAL_WEBPACK=$NEXT_PRIVATE_LOCAL_WEBPACK
ENV NEXT_PUBLIC_CHAT_WS_API_URL=${NEXT_PUBLIC_CHAT_WS_API_URL}

WORKDIR /app

ENV NODE_ENV=production
# Uncomment the following line in case you want to disable telemetry during runtime.
# ENV NEXT_TELEMETRY_DISABLED 1

RUN groupadd --system --gid 1001 nodejs
RUN useradd --system --uid 1001 --gid 1001 nextjs

# Install curl for health checks
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl \
 && rm -rf /var/lib/apt/lists/*

COPY --from=builder /workspace/$SERVICE_PATH/public* ./public

# Set the correct permission for prerender cache
RUN mkdir .next
RUN chown nextjs:nodejs .next

# Automatically leverage output traces to reduce image size
# https://nextjs.org/docs/advanced-features/output-file-tracing
COPY --from=builder --chown=nextjs:nodejs /workspace/$SERVICE_PATH/.next/standalone ./
# Workspace installs hoist some runtime packages (for example `react`) to the
# repo root, while Next standalone only copies the traced app tree.
COPY --from=builder --chown=nextjs:nodejs /workspace/node_modules ./node_modules
COPY --from=builder --chown=nextjs:nodejs /workspace/$SERVICE_PATH/.next/static ./.next/static
COPY ./$SERVICE_PATH/*.* ./

USER nextjs

EXPOSE $SERVICE_PORT

ENV PORT=$SERVICE_PORT

# Health check against the Next.js server
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -sf http://localhost:${PORT:-3000}/ || exit 1

# server.js is created by next build from the standalone output
# https://nextjs.org/docs/pages/api-reference/next-config-js/output
CMD HOSTNAME="0.0.0.0" node server.js
